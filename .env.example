# Copy this file to `.env` for local development. Never commit a real `.env`.

# --- AWS connection settings (ignored when USE_MOCK_DATA=true) ---
AWS_REGION=ca-central-1
AWS_PROFILE=

# --- Demo mode ---
# When true, the CLI uses the built-in mock data generator instead of
# calling real AWS APIs. Set to false once you've connected a real
# Security Hub-enabled AWS account (see README "Connecting to a real
# AWS Security Hub environment").
USE_MOCK_DATA=true

# --- Fetch behaviour ---
MIN_SEVERITY=LOW
MAX_FINDINGS_PER_FETCH=500

# --- Storage / output paths ---
VULN_REGISTER_DB_PATH=data/vulnerability_register.db
REPORT_OUTPUT_DIR=reports
RUNBOOK_OUTPUT_DIR=runbooks

# --- Logging ---
LOG_LEVEL=INFO
